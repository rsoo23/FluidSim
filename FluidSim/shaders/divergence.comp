#version 460 core
layout(local_size_x = 8, local_size_y = 8, local_size_z = 1) in;
layout(r32f, binding = 0) readonly uniform image2D velXTexture;
layout(r32f, binding = 1) readonly uniform image2D velYTexture;
layout(r32f, binding = 2) writeonly uniform image2D divTexture;

uniform float screenWidth;
uniform float screenHeight;

void main() {
    ivec2 id = ivec2( gl_GlobalInvocationID.xy );
    float velX = imageLoad(velXTexture, id).r;
    float velY = imageLoad(velYTexture, id).r;

    ivec2 coordLeft     = id + ivec2(-1, 0);
    ivec2 coordRight    = id + ivec2(1, 0);
    ivec2 coordUp       = id + ivec2(0, 1);
    ivec2 coordDown     = id + ivec2(0, -1);

    float velXLeft    = imageLoad(velXTexture, coordLeft).r;
    float velXRight   = imageLoad(velXTexture, coordRight).r;
    float velYUp      = imageLoad(velYTexture, coordUp).r;
    float velYDown    = imageLoad(velYTexture, coordDown).r;

    float leftX     = id.x > 0                  ? velXLeft     : velX;
    float rightX    = id.x < screenWidth - 1    ? velXRight    : velX;
    float upY       = id.y > 0                  ? velYUp       : velY;
    float downY     = id.y < screenHeight - 1   ? velYDown     : velY;

    float finalDiv = -0.5 * ((rightX - leftX) + (downY - upY));

    imageStore(divTexture, id, vec4(finalDiv, 0.0, 0.0, 0.0));
}
